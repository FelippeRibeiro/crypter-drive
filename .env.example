HTTP_PORT=8080
DATABASE_URL=postgres://crypter:crypter@postgres:5432/crypter?sslmode=disable
JWT_SECRET=change-this-secret
# 32-byte key in base64. Example generated with:
# openssl rand -base64 32
MASTER_KEY_BASE64=replace-with-base64-32-bytes
GOOGLE_CREDENTIALS_FILE=/app/credentials.json
GOOGLE_TOKEN_FILE=/app/token.json
GOOGLE_DRIVE_ROOT_FOLDER=crypter
